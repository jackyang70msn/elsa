{
  "name": "elsa",
  "version": "3.0.0",
  "description": "Telegram bridge for Claude Code - use Claude from your phone",
  "type": "module",
  "bin": {
    "elsa": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && chmod +x dist/cli.js",
    "start": "tsx src/daemon.ts",
    "dev": "tsx watch src/daemon.ts",
    "cli": "tsx src/cli.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "keygen": "node scripts/keygen.mjs",
    "prepublishOnly": "npm run build"
  },
  "author": "Anas Nadeem",
  "license": "MIT",
  "homepage": "https://clautel.com",
  "keywords": [
    "elsa",
    "claude",
    "anthropic",
    "telegram",
    "claude-code",
    "ai",
    "mobile"
  ],
  "dependencies": {
    "@ngrok/ngrok": "^1",
    "discord.js": "^14.25.1",
    "dotenv": "^16",
    "grammy": "^1",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4",
    "typescript": "^5"
  }
}
